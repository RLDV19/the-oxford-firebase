               <div className="mt-4 pt-3 border-t border-gray-200 space-y-2">
                 <button onClick={() => {
                    onUpdateSettings('name', defaultCertSettings.name);
                    onUpdateSettings('date', defaultCertSettings.date);
                    onUpdateSettings('code', defaultCertSettings.code);
