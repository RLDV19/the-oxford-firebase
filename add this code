                  if (e.target.checked) {
                     setHomework('');
                     setHomeworkStatus('No Homework');
                  } else {
                     setHomeworkStatus('Not Submitted');
                  }
                }} 
                className="rounded text-indigo-600 focus:ring-indigo-500 w-4 h-4 cursor-pointer" 
              />
